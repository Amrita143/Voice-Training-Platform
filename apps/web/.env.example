# Firebase web app config — get values via:
#   firebase apps:sdkconfig WEB
# Copy this file to .env.local and fill in.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=astra-voice-training.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=astra-voice-training
VITE_FIREBASE_STORAGE_BUCKET=astra-voice-training.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to use the local Firebase emulators
VITE_USE_EMULATORS=false
